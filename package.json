{
  "name": "n8n-nodes-agorapulse",
  "version": "0.1.0",
  "description": "n8n nodes for Agorapulse social media management API",
  "keywords": [
    "n8n-community-node-package",
    "agorapulse",
    "social-media"
  ],
  "license": "MIT",
  "author": {
    "name": "Vladimir Orany",
    "email": "vladimir@orany.cz"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/telegraphic-dev/n8n-nodes-agorapulse.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials --ext .ts --fix",
    "lintcheck": "eslint nodes credentials --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/AgorapulseApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Agorapulse/Agorapulse.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "gulp": "^4.0.2",
    "n8n-workflow": "*",
    "prettier": "^3.0.0",
    "typescript": "~5.3.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
