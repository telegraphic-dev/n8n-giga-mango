{
  "name": "@telegraphic-dev/n8n-giga-mango",
  "version": "0.1.0",
  "description": "n8n community node for social media management",
  "keywords": [
    "n8n-community-node-package",
    "social-media",
    "publishing"
  ],
  "license": "MIT",
  "author": {
    "name": "Vladimir Orany",
    "email": "vladimir@orany.cz"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/telegraphic-dev/n8n-giga-mango.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && npm run copy-icons",
    "copy-icons": "cp nodes/Agorapulse/*.svg dist/nodes/Agorapulse/ 2>/dev/null || true",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/AgorapulseApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Agorapulse/Agorapulse.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "n8n-workflow": "*",
    "typescript": "~5.3.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
